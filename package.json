{
  "name": "skillprompts",
  "displayName": "SkillPrompts",
  "version": "1.1.0",
  "description": "Boost your AI workflow. Create, organize, and reuse prompts instantly across all your favorite chat platforms.",
  "author": "Adem Kouki <ademkingnew@gmail.com>",
  "scripts": {
    "dev": "plasmo dev",
    "dev:verbose": "plasmo dev --verbose",
    "dev:firefox": "plasmo dev --target=firefox-mv3",
    "build": "plasmo build",
    "build:source": "plasmo build --source-maps",
    "build:chrome": "plasmo build --target=chrome-mv3 --zip",
    "build:firefox": "plasmo build --target=firefox-mv3 --zip --source-maps",
    "package": "plasmo package",
    "build:all": "npm run build:chrome && npm run build:firefox"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "3.4.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "postcss": "8.4.33",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://chatgpt.com/*",
      "https://chat.openai.com/*",
      "https://gemini.google.com/*"
    ],
    "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self'; frame-src https://www.youtube.com https://www.youtube-nocookie.com"
    },
    "browser_specific_settings": {
      "gecko": {
        "id": "ademking@skillprompts",
        "data_collection_permissions": {
          "required": [
            "none"
          ]
        }
      }
    }
  }
}